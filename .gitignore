# .gitignore 파일 예시

# 1순위: 보안 파일
# -----------------
# API 키와 비밀번호가 담긴 .env 파일을 절대 업로드하지 않음
.env


# 파이썬 관련 파일
# -----------------
# 가상환경 폴더 (이름이 venv, .venv, env 등 뭐든)
venv/
.venv/
env/

# 파이썬 컴파일 캐시 (로컬에서만 필요함)
__pycache__/
*.pyc
*.pyo


# OS (운영체제)별 시스템 파일
# -----------------
# macOS
.DS_Store
# Windows
Thumbs.db


# 프로젝트 관련 파일
# -----------------
# (미래를 위한 조언)
# LangChain이 생성할 로컬 Vector DB 폴더.
# DB 파일은 매우 크고, 로컬마다 다르므로 Git에 올리지 않음.
db/
*.db
chroma_db/