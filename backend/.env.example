# ─────────────────────────────────────────────
#  .env.example  —  이 파일을 .env 로 복사한 뒤
#                   실제 값을 채워 넣으세요.
#  cp .env.example .env
# ─────────────────────────────────────────────

# ── Neon Database (필수) ────────────────────
# Neon 콘솔 → 프로젝트 → Connection Details 에서
# "Connection string" 을 복사하세요.
# 드라이버 접두사는 반드시 postgresql+psycopg2:// 로 바꾸세요.
#
# 예시:
# DATABASE_URL=postgresql+psycopg2://alice:pass@ep-cool-lab-123.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── JWT 서명 키 (필수) ──────────────────────
# 충분히 긴 랜덤 문자열을 사용하세요.
# 생성 예시: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret

# ── API 서버 포트 (선택, 기본: 8000) ────────
PORT=8000
