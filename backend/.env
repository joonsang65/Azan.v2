# 파일 기능: 로컬 실행에 필요한 환경변수(DATABASE_URL, JWT_SECRET)를 설정한다.
# Local Postgres on your Mac:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/azan
# Postgres in docker-compose with 5432 port mapping to host:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/azan
# If API runs inside Docker and Postgres service is named "db":
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/azan
JWT_SECRET=dev-secret
